+    n: trimmedName,
+    m: config.mascotId,
+    l: config.customLogoUrl,
+    f: config.weeklyFocus,
+    g: config.goalText,
+    mg: config.managerName,
+  };
+  return `${TEAM_TOKEN_PREFIX}${toBase64Url(JSON.stringify(payload))}`;
